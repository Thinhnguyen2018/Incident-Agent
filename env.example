# ─────────────────────────────────────────────────────────────
# HƯỚNG DẪN: Copy file này thành .env rồi điền giá trị thực
#   cp .env.example .env
# KHÔNG commit file .env lên GitHub
# ─────────────────────────────────────────────────────────────


# ─── Gmail (Gửi Email) ───────────────────────────────────────
# Lấy từ Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Địa chỉ Gmail dùng để gửi email (phải khớp với tài khoản xác thực tại /auth/gmail)
GMAIL_SENDER_EMAIL=
# Không cần thay đổi nếu chạy trên server chính
GMAIL_REDIRECT_URI=https://greennode-incident-agent.site/auth/gmail/callback
# Đường dẫn file lưu token Gmail (không cần thay đổi)
GMAIL_TOKEN_FILE=gmail_token.json


# ─── Microsoft Entra ID (Đăng nhập người dùng) ───────────────
# Lấy từ Azure Portal → Microsoft Entra ID → App registrations
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Không cần thay đổi nếu chạy trên server chính
MS_REDIRECT_URI=https://greennode-incident-agent.site/auth/login/callback


# ─── Kiểm soát truy cập ──────────────────────────────────────
# Chỉ email kết thúc bằng domain này mới được đăng nhập
ALLOWED_EMAIL_DOMAIN=vng.com.vn
# Đường dẫn file whitelist (mỗi email 1 dòng)
WHITELIST_FILE=whitelist.txt


# ─── Flask ───────────────────────────────────────────────────
# Tạo bằng: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
# Dùng "production" trên server thật, "development" khi dev local
FLASK_ENV=production


# ─── Dịch tự động Việt → Anh (9router) ──────────────────────
# Để trống ROUTER_API_KEY sẽ tắt chức năng dịch tự động
ROUTER_BASE_URL=http://127.0.0.1:20128/v1
ROUTER_API_KEY=
ROUTER_MODEL=if/glm-4.7
ROUTER_TIMEOUT=20
